# Server
PORT=3000

# SQLite database file (created on first run)
DB_PATH=data/repopulse.db

# Dashboard auth (optional). If CLIENT_ID/SECRET/SESSION_SECRET are all set, the
# dashboard requires GitHub login; otherwise it runs OPEN (dev, localhost only).
# Use your GitHub App's OAuth credentials and add BASE_URL/auth/callback as a
# callback URL in the App settings.
BASE_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=
# Comma-separated GitHub logins allowed to sign in (empty = nobody)
GITHUB_ALLOWED_LOGINS=

# GitHub App / Webhook shared secret (set the same value in the App's webhook config)
GITHUB_WEBHOOK_SECRET=replace-me

# GitLab webhook secret token (X-Gitlab-Token), set the same value on the project/group hook
GITLAB_WEBHOOK_SECRET=replace-me

# Sink credentials referenced from config/subscriptions.yaml
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# Microsoft Teams: a Workflows (Power Automate) incoming webhook URL
TEAMS_WEBHOOK_URL=https://prod-00.westus.logic.azure.com:443/workflows/xxx/triggers/manual/paths/invoke?...
# LINE Messaging API: long-lived channel access token + destination id
LINE_CHANNEL_ACCESS_TOKEN=replace-me
LINE_TO=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
