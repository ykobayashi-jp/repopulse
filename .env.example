# Server
PORT=3000

# SQLite database file (created on first run)
DB_PATH=data/repopulse.db

# GitHub App / Webhook shared secret (set the same value in the App's webhook config)
GITHUB_WEBHOOK_SECRET=replace-me

# GitLab webhook secret token (X-Gitlab-Token), set the same value on the project/group hook
GITLAB_WEBHOOK_SECRET=replace-me

# Sink credentials referenced from config/subscriptions.yaml
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# LINE Messaging API: long-lived channel access token + destination id
LINE_CHANNEL_ACCESS_TOKEN=replace-me
LINE_TO=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
